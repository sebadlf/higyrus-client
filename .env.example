# Required
HIGYRUS_USER=tu_usuario
HIGYRUS_PASSWORD=tu_password
HIGYRUS_BASE_URL=https://cliente.aunesa.com/Irmo

# Optional — single-tenant installations can leave it empty; it is still
# sent in the login body as "" to keep the request shape consistent.
HIGYRUS_CLIENT_ID=

# Optional — used by main.py smoke check
HIGYRUS_TEST_ACCOUNT_ID=
HIGYRUS_TEST_TIPO_CUENTA=
HIGYRUS_TEST_NIVEL=
